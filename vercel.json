{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".vuepress/dist",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": ".vuepress/dist",
        "maxDuration": 300
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    }
  ]
}
